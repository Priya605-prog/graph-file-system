#include<stdio.h>
#include<stdlib.h>
#define SIZE 20

int source, V, E, visited[SIZE], G[SIZE][SIZE];
int queue[SIZE], front = -1, rear = -1;

// Enqueue
void enqueue(int x)
{
    if(rear == SIZE-1)
        return;
    if(front == -1)
        front = 0;
    queue[++rear] = x;
}

// Dequeue
int dequeue()
{
    if(front == -1)
        return -1;

    int x = queue[front++];
    if(front > rear)
        front = rear = -1;

    return x;
}

// BFS function
void BFS(int i)
{
    int j;
    enqueue(i);
    visited[i] = 1;

    while(front != -1)
    {
        int node = dequeue();
        printf("%d->", node + 1);

        for(j = 0; j < V; j++)
        {
            if(G[node][j] == 1 && visited[j] == 0)
            {
                enqueue(j);
                visited[j] = 1;
            }
        }
    }
}

int main()
{
    int i, j, v1, v2;

    printf("\t\t\tGraphs\n");

    printf("Enter the no of edges:");
    scanf("%d", &E);

    printf("Enter the no of vertices:");
    scanf("%d", &V);

    // Initialize
    for(i = 0; i < V; i++)
    {
        visited[i] = 0;
        for(j = 0; j < V; j++)
            G[i][j] = 0;
    }

    // Input edges
    for(i = 0; i < E; i++)
    {
        printf("Enter the edges(format:v1 v2):");
        scanf("%d %d", &v1, &v2);
        G[v1-1][v2-1] = 1;
        G[v2-1][v1-1] = 1; // undirected graph
    }

    // Display adjacency matrix
    printf("\nAdjacency Matrix:\n");
    for(i = 0; i < V; i++)
    {
        for(j = 0; j < V; j++)
            printf("%d ", G[i][j]);
        printf("\n");
    }

    printf("Enter the source:");
    scanf("%d", &source);

    // BFS traversal
    printf("BFS Traversal: ");
    BFS(source - 1);

    return 0;
}
